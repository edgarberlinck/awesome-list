---
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';

export async function getStaticPaths() {
  return [
    { params: { category: 'livros' } },
    { params: { category: 'comunidades' } },
    { params: { category: 'exercicios-tecnicos' } },
    { params: { category: 'freelas-disfarcados' } },
  ];
}

const { category } = Astro.params;

const categoryConfig: Record<string, any> = {
  'livros': {
    title: '📖 Livros',
    description: 'Referências essenciais em desenvolvimento de software',
  },
  'comunidades': {
    title: '👥 Comunidades',
    description: 'Espaços para networking e aprendizado colaborativo',
  },
  'exercicios-tecnicos': {
    title: '💪 Exercícios Técnicos',
    description: 'Desafios de programação propostos por empresas',
  },
  'freelas-disfarcados': {
    title: '🎭 Freelas Disfarçados',
    description: 'Testes que parecem desafios mas solicitam trabalho real',
  },
};

const config = categoryConfig[category!];

function loadResources() {
  const categoryPath = path.join(process.cwd(), category!);
  if (!fs.existsSync(categoryPath)) return [];
  
  const files = fs.readdirSync(categoryPath).filter(f => f.endsWith('.md') && f !== 'README.md');
  
  return files.map(file => {
    const filePath = path.join(categoryPath, file);
    const content = fs.readFileSync(filePath, 'utf-8');
    
    // Extract title from first # heading
    const titleMatch = content.match(/^#\s+(.+)$/m);
    const title = titleMatch ? titleMatch[1] : file.replace('.md', '');
    
    // Remove title from content and parse markdown
    const contentWithoutTitle = content.replace(/^#\s+.+$/m, '').trim();
    const html = marked(contentWithoutTitle);
    
    return {
      slug: file.replace('.md', ''),
      title,
      html,
    };
  }).sort((a, b) => a.title.localeCompare(b.title));
}

const resources = loadResources();
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{config.title} | Tech Resources Hub</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      line-height: 1.6;
      color: #333;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 2rem;
    }
    .container {
      max-width: 1400px;
      margin: 0 auto;
      background: white;
      border-radius: 20px;
      padding: 3rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .back-link {
      display: inline-block;
      margin-bottom: 2rem;
      color: #667eea;
      text-decoration: none;
      font-weight: 500;
    }
    .back-link:hover {
      text-decoration: underline;
    }
    h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .description {
      font-size: 1.1rem;
      color: #666;
      margin-bottom: 2rem;
    }
    .stats {
      background: #f5f7fa;
      padding: 1rem;
      border-radius: 10px;
      margin-bottom: 2rem;
      font-weight: 500;
    }
    .resources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }
    .resource-card {
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      padding: 1.5rem;
      transition: all 0.3s ease;
    }
    .resource-card:hover {
      border-color: #667eea;
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
      transform: translateY(-2px);
    }
    .resource-title {
      font-size: 1.25rem;
      font-weight: bold;
      margin-bottom: 1rem;
      color: #667eea;
    }
    .resource-content {
      color: #4b5563;
      line-height: 1.6;
    }
    .resource-content h2 {
      font-size: 1rem;
      font-weight: 600;
      margin-top: 1rem;
      margin-bottom: 0.5rem;
      color: #1f2937;
    }
    .resource-content p {
      margin-bottom: 0.75rem;
    }
    .resource-content ul {
      margin-left: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .resource-content a {
      color: #667eea;
      text-decoration: none;
    }
    .resource-content a:hover {
      text-decoration: underline;
    }
    .resource-content code {
      background: #f3f4f6;
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      font-size: 0.875em;
      color: #764ba2;
    }
    .no-resources {
      text-align: center;
      padding: 3rem;
      color: #999;
      font-style: italic;
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/" class="back-link">← Voltar para home</a>
    
    <h1>{config.title}</h1>
    <p class="description">{config.description}</p>
    
    <div class="stats">
      📊 Total de recursos: {resources.length}
    </div>

    {resources.length === 0 ? (
      <div class="no-resources">
        Nenhum recurso adicionado ainda. Seja o primeiro a contribuir!
      </div>
    ) : (
      <div class="resources-grid">
        {resources.map((resource) => (
          <div class="resource-card">
            <div class="resource-title">{resource.title}</div>
            <div class="resource-content" set:html={resource.html} />
          </div>
        ))}
      </div>
    )}
  </div>
</body>
</html>
