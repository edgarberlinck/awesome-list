---
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';

export async function getStaticPaths() {
  return [
    { params: { category: 'livros' } },
    { params: { category: 'comunidades' } },
    { params: { category: 'exercicios-tecnicos' } },
    { params: { category: 'freelas-disfarcados' } },
    { params: { category: 'newsletters' } },
  ];
}

const { category } = Astro.params;
const base = import.meta.env.BASE_URL;

const categoryConfig: Record<string, any> = {
  'livros': {
    title: '📖 Livros',
    description: 'Referências essenciais em desenvolvimento de software',
  },
  'comunidades': {
    title: '👥 Comunidades',
    description: 'Espaços para networking e aprendizado colaborativo',
  },
  'exercicios-tecnicos': {
    title: '💪 Exercícios Técnicos',
    description: 'Desafios de programação propostos por empresas',
  },
  'freelas-disfarcados': {
    title: '🎭 Freelas Disfarçados',
    description: 'Testes que parecem desafios mas solicitam trabalho real',
  },
  'newsletters': {
    title: '📬 Newsletters',
    description: 'Conteúdo curado direto na sua caixa de entrada',
  },
};

const config = categoryConfig[category!];

function loadResources() {
  const categoryPath = path.join(process.cwd(), category!);
  if (!fs.existsSync(categoryPath)) return [];
  
  const files = fs.readdirSync(categoryPath).filter(f => f.endsWith('.md') && f !== 'README.md');
  
  return files.map(file => {
    const filePath = path.join(categoryPath, file);
    const content = fs.readFileSync(filePath, 'utf-8');
    
    // Extract title from first # heading
    const titleMatch = content.match(/^#\s+(.+)$/m);
    const title = titleMatch ? titleMatch[1] : file.replace('.md', '');
    
    // Extract tags from content (looking for `tag` format)
    const tagsMatch = content.match(/`([^`]+)`/g);
    const tags = tagsMatch ? tagsMatch.map(tag => tag.replace(/`/g, '')) : [];
    
    // Remove title from content and parse markdown
    const contentWithoutTitle = content.replace(/^#\s+.+$/m, '').trim();
    const html = marked(contentWithoutTitle);
    
    return {
      slug: file.replace('.md', ''),
      title,
      html,
      tags,
      rawContent: content,
    };
  }).sort((a, b) => a.title.localeCompare(b.title));
}

const resources = loadResources();

// Get all unique tags
const allTags = [...new Set(resources.flatMap(r => r.tags))].sort();
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{config.title} | Tech Resources Hub</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: #1a202c;
      background: #f8fafc;
      min-height: 100vh;
    }
    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
      padding: 3rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      opacity: 0.3;
    }
    .header-content {
      max-width: 1400px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2rem;
      color: white;
      text-decoration: none;
      font-weight: 500;
      padding: 0.5rem 1rem;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      border-radius: 50px;
      border: 1px solid rgba(255,255,255,0.3);
      transition: all 0.3s ease;
    }
    .back-link:hover {
      background: rgba(255,255,255,0.25);
      transform: translateX(-5px);
    }
    h1 {
      font-size: 3.5rem;
      font-weight: 900;
      margin-bottom: 0.75rem;
      color: white;
      text-shadow: 0 4px 20px rgba(0,0,0,0.2);
      letter-spacing: -1px;
    }
    .description {
      font-size: 1.3rem;
      color: rgba(255,255,255,0.95);
      margin-bottom: 1.5rem;
      font-weight: 300;
    }
    .stats {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(10px);
      padding: 0.75rem 1.5rem;
      border-radius: 50px;
      color: white;
      font-weight: 600;
      border: 1px solid rgba(255,255,255,0.3);
    }
    .container {
      max-width: 1400px;
      margin: -2rem auto 0;
      padding: 0 2rem 4rem;
      position: relative;
      z-index: 2;
    }
    .resources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 2rem;
    }
    .resource-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid #e2e8f0;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      position: relative;
      overflow: hidden;
    }
    .resource-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .resource-card:hover::before {
      opacity: 1;
    }
    .resource-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(102, 126, 234, 0.2);
      border-color: #667eea;
    }
    .resource-title {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 1.25rem;
      color: #1a202c;
      line-height: 1.3;
    }
    .resource-content {
      color: #4a5568;
      line-height: 1.8;
      font-size: 0.95rem;
    }
    .resource-content h2 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      color: #2d3748;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .resource-content h2::before {
      content: '▸';
      color: #667eea;
      font-size: 1.2rem;
    }
    .resource-content p {
      margin-bottom: 1rem;
    }
    .resource-content ul {
      margin-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .resource-content li {
      margin-bottom: 0.5rem;
      padding-left: 0.5rem;
    }
    .resource-content strong {
      color: #2d3748;
      font-weight: 600;
    }
    .resource-content a {
      color: #667eea;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.2s ease;
      position: relative;
    }
    .resource-content a::after {
      content: '→';
      margin-left: 0.25rem;
      transition: transform 0.2s ease;
      display: inline-block;
    }
    .resource-content a:hover::after {
      transform: translateX(3px);
    }
    .resource-content a:hover {
      color: #764ba2;
    }
    .resource-content code {
      background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
      padding: 0.2rem 0.5rem;
      border-radius: 6px;
      font-size: 0.875em;
      color: #667eea;
      font-weight: 600;
      border: 1px solid #e2e8f0;
    }
    .no-resources {
      text-align: center;
      padding: 4rem 2rem;
      background: white;
      border-radius: 16px;
      border: 2px dashed #cbd5e0;
    }
    .no-resources::before {
      content: '🤷‍♂️';
      font-size: 4rem;
      display: block;
      margin-bottom: 1rem;
    }
    .no-resources p {
      color: #4a5568;
      font-size: 1.2rem;
      line-height: 1.6;
      max-width: 600px;
      margin: 0 auto;
    }
    .no-resources .contribute-link {
      display: inline-block;
      margin-top: 2rem;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 50px;
      text-decoration: none;
      font-weight: 600;
      transition: transform 0.3s ease;
    }
    .no-resources .contribute-link:hover {
      transform: scale(1.05);
    }
    .filter-section {
      margin-bottom: 2rem;
      padding: 1.5rem;
      background: white;
      border-radius: 12px;
      border: 1px solid #e2e8f0;
    }
    .filter-title {
      font-size: 1rem;
      font-weight: 600;
      color: #2d3748;
      margin-bottom: 1rem;
    }
    .filter-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .filter-tag {
      padding: 0.5rem 1rem;
      background: #f7fafc;
      border: 2px solid #e2e8f0;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.2s ease;
      font-size: 0.9rem;
      color: #4a5568;
    }
    .filter-tag:hover {
      background: #edf2f7;
      border-color: #cbd5e0;
    }
    .filter-tag.active {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border-color: #667eea;
    }
    .filter-tag.all {
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="header-content">
      <a href={base} class="back-link">← Voltar</a>
      
      <h1>{config.title}</h1>
      <p class="description">{config.description}</p>
      
      <div class="stats">
        📊 {resources.length} recursos disponíveis
      </div>
    </div>
  </div>

  <div class="container">
    {resources.length === 0 ? (
      <div class="no-resources">
        <p>
          <strong>Essa página não vai se alimentar sozinha.</strong><br />
          É como dizem por aí: Quem sabe contribui, quem não sabe reclama.
        </p>
        <a href="https://github.com/edgarberlinck/awesome-list/blob/main/CONTRIBUTING.md" target="_blank" class="contribute-link">
          📝 Seja o primeiro a contribuir
        </a>
      </div>
    ) : (
      <>
        {allTags.length > 0 && (
          <div class="filter-section">
            <div class="filter-title">🏷️ Filtrar por tag:</div>
            <div class="filter-tags">
              <button class="filter-tag all active" data-tag="all">Todos ({resources.length})</button>
              {allTags.map(tag => {
                const count = resources.filter(r => r.tags.includes(tag)).length;
                return (
                  <button class="filter-tag" data-tag={tag}>
                    {tag} ({count})
                  </button>
                );
              })}
            </div>
          </div>
        )}
        
        <div class="resources-grid">
          {resources.map((resource) => (
            <div class="resource-card" data-tags={JSON.stringify(resource.tags)}>
              <div class="resource-title">{resource.title}</div>
              <div class="resource-content" set:html={resource.html} />
            </div>
          ))}
        </div>
      </>
    )}
  </div>

  <script>
    // Filter functionality
    const filterTags = document.querySelectorAll('.filter-tag');
    const resourceCards = document.querySelectorAll('.resource-card');

    filterTags.forEach(tag => {
      tag.addEventListener('click', () => {
        const selectedTag = tag.dataset.tag;
        
        // Update active state
        filterTags.forEach(t => t.classList.remove('active'));
        tag.classList.add('active');
        
        // Filter cards
        resourceCards.forEach(card => {
          const cardTags = JSON.parse(card.dataset.tags || '[]');
          
          if (selectedTag === 'all' || cardTags.includes(selectedTag)) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</body>
</html>
