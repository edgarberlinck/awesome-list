---
import fs from 'fs';
import path from 'path';

const categories = [
  { 
    slug: 'livros', 
    title: '📖 Livros', 
    icon: '📖',
    description: 'Referências essenciais para crescimento técnico'
  },
  { 
    slug: 'comunidades', 
    title: '👥 Comunidades', 
    icon: '👥',
    description: 'Conecte-se com outros devs e aprenda junto'
  },
  { 
    slug: 'exercicios-tecnicos', 
    title: '💪 Exercícios Técnicos', 
    icon: '💪',
    description: 'Desafios de código para treinar suas skills'
  },
  { 
    slug: 'freelas-disfarcados', 
    title: '🎭 Freelas Disfarçados', 
    icon: '🎭',
    description: 'Testes técnicos que pedem trabalho de graça'
  },
  { 
    slug: 'newsletters', 
    title: '📬 Newsletters', 
    icon: '📬',
    description: 'Conteúdo de qualidade direto no seu email'
  },
];

const base = import.meta.env.BASE_URL;

function getResourceCount(categorySlug: string): number {
  const categoryPath = path.join(process.cwd(), categorySlug);
  if (!fs.existsSync(categoryPath)) return 0;
  return fs.readdirSync(categoryPath).filter(f => f.endsWith('.md') && f !== 'README.md').length;
}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tech Resources Hub 🚀</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      line-height: 1.6;
      color: #1a202c;
      background: #0f172a;
      min-height: 100vh;
      padding: 0;
    }
    .hero {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
      padding: 4rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      opacity: 0.3;
    }
    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 800px;
      margin: 0 auto;
    }
    h1 {
      font-size: 4rem;
      font-weight: 900;
      margin-bottom: 1rem;
      color: white;
      text-shadow: 0 4px 20px rgba(0,0,0,0.3);
      letter-spacing: -2px;
    }
    .subtitle {
      font-size: 1.5rem;
      color: rgba(255,255,255,0.95);
      margin-bottom: 2rem;
      font-weight: 300;
    }
    .stats-badge {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(10px);
      padding: 0.5rem 1.5rem;
      border-radius: 50px;
      color: white;
      font-weight: 600;
      border: 1px solid rgba(255,255,255,0.3);
    }
    .container {
      max-width: 1400px;
      margin: -3rem auto 0;
      padding: 0 2rem 4rem;
      position: relative;
      z-index: 2;
    }
    .categories {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
    }
    .category-card {
      background: white;
      border-radius: 20px;
      padding: 2.5rem;
      text-decoration: none;
      color: inherit;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid #e2e8f0;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      position: relative;
      overflow: hidden;
    }
    .category-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 6px;
      background: linear-gradient(90deg, #667eea, #764ba2);
      transform: scaleX(0);
      transition: transform 0.4s ease;
    }
    .category-card:hover::before {
      transform: scaleX(1);
    }
    .category-card:hover {
      transform: translateY(-8px) scale(1.02);
      box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);
      border-color: #667eea;
    }
    .category-icon {
      font-size: 4rem;
      margin-bottom: 1.5rem;
      display: block;
      filter: drop-shadow(0 4px 10px rgba(102, 126, 234, 0.3));
    }
    .category-title {
      font-size: 1.75rem;
      font-weight: 800;
      margin-bottom: 1rem;
      color: #1a202c;
    }
    .category-description {
      font-size: 0.95rem;
      color: #718096;
      margin-bottom: 1.5rem;
      line-height: 1.5;
    }
    .category-count {
      color: #718096;
      font-size: 1rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .category-count::before {
      content: '📚';
      font-size: 1.2rem;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      padding: 0.5rem 1.25rem;
      border-radius: 50px;
      font-size: 0.9rem;
      font-weight: 600;
      box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }
    .badge::after {
      content: '→';
      font-size: 1.2rem;
      transition: transform 0.3s ease;
    }
    .category-card:hover .badge::after {
      transform: translateX(5px);
    }
    footer {
      margin-top: 4rem;
      text-align: center;
      color: #a0aec0;
      padding: 3rem 2rem;
      background: #1a202c;
      border-top: 1px solid #2d3748;
    }
    footer p {
      margin-bottom: 0.5rem;
    }
    footer a {
      color: #667eea;
      text-decoration: none;
      transition: color 0.3s ease;
    }
    footer a:hover {
      color: #764ba2;
    }
  </style>
</head>
<body>
  <div class="hero">
    <div class="hero-content">
      <h1>Tech Resources Hub 🚀</h1>
      <p class="subtitle">Recursos curados para desenvolvedores que querem evoluir</p>
      <span class="stats-badge">✨ {categories.reduce((acc, cat) => acc + getResourceCount(cat.slug), 0)} recursos disponíveis</span>
    </div>
  </div>

  <div class="container">
    <div class="categories">
      {categories.map(cat => (
        <a href={`${base}/${cat.slug}/`} class="category-card">
          <span class="category-icon">{cat.icon}</span>
          <div class="category-title">{cat.title}</div>
          <div class="category-description">{cat.description}</div>
          <div class="category-count">{getResourceCount(cat.slug)} recursos</div>
          <span class="badge">Explorar</span>
        </a>
      ))}
    </div>
  </div>

  <div style="background: white; padding: 4rem 2rem; margin-top: 4rem;">
    <div style="max-width: 1400px; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; color: #1a202c;">
        🤝 Contribua com a Comunidade
      </h2>
      <p style="font-size: 1.2rem; color: #4a5568; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
        Todo conteúdo deste site foi adicionado por desenvolvedores como você. 
        Compartilhe seus recursos favoritos!
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/edgarberlinck/awesome-list/blob/main/CONTRIBUTING.md" 
           target="_blank"
           style="display: inline-block; background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 1rem 2rem; border-radius: 50px; text-decoration: none; font-weight: 600; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4); transition: all 0.3s ease;">
          📝 Como Contribuir
        </a>
        <a href="https://github.com/edgarberlinck/awesome-list/issues/new" 
           target="_blank"
           style="display: inline-block; background: white; color: #667eea; padding: 1rem 2rem; border-radius: 50px; text-decoration: none; font-weight: 600; border: 2px solid #667eea; transition: all 0.3s ease;">
          ⚠️ Reportar Problema
        </a>
      </div>
    </div>
  </div>

  <footer>
    <p><strong>Tech Resources Hub</strong> - Conhecimento compartilhado pela comunidade</p>
    <p>
      <a href="https://github.com/edgarberlinck/awesome-list/blob/main/CONTRIBUTING.md" target="_blank">Como Contribuir</a>
      ·
      <a href="https://github.com/edgarberlinck/awesome-list/issues/new" target="_blank">Reportar Problema</a>
      ·
      <a href="https://github.com/edgarberlinck/awesome-list" target="_blank">GitHub</a>
    </p>
    <p style="margin-top: 1rem; font-size: 0.9rem; color: #a0aec0;">
      ⚠️ Todo conteúdo é contribuído por usuários da comunidade. 
      Encontrou algo errado? <a href="https://github.com/edgarberlinck/awesome-list/issues/new" target="_blank" style="color: #667eea;">Abra uma issue</a>.
    </p>
    <p style="margin-top: 0.5rem;">MIT © 2024</p>
  </footer>
</body>
</html>
